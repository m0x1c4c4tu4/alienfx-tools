<?xml version="1.0" encoding="utf-8"?>
<ContentDialog x:Class="winrt::AlienFX::Dialogs::ZoneSelectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Select Zones"
    PrimaryButtonText="OK"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary">
    <StackPanel Spacing="12" MinWidth="300">
        <ListView x:Name="ZonesList" MinHeight="200" SelectionMode="Multiple">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <CheckBox IsChecked="{Binding IsSelected}" />
                        <TextBlock Text="{Binding ZoneName}" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Add Zone" />
            <Button Content="Remove Zone" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
