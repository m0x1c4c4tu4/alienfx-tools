<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="winrt::AlienFX::Controls::GaugeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource AlienSurface}" CornerRadius="8" BorderBrush="{StaticResource AlienBorder}" BorderThickness="1" Padding="16">
        <StackPanel HorizontalAlignment="Center">
            <Viewbox Width="120" Height="120">
                <Canvas Width="100" Height="100">
                    <Path x:Name="GaugeBackground" Stroke="{StaticResource AlienBorder}" StrokeThickness="8" Fill="None" />
                    <Path x:Name="GaugeValue" Stroke="{StaticResource AlienAccent}" StrokeThickness="8" Fill="None" />
                    <TextBlock x:Name="ValueText" Text="0" Canvas.Left="35" Canvas.Top="35" FontSize="16" Foreground="{StaticResource AlienTextPrimary}" />
                </Canvas>
            </Viewbox>
            <TextBlock x:Name="Label" Text="Gauge" HorizontalAlignment="Center" Foreground="{StaticResource AlienTextSecondary}" Margin="0,4,0,0" />
            <TextBlock x:Name="MinMaxText" Text="Min: 0 | Max: 100" HorizontalAlignment="Center" Foreground="{StaticResource AlienTextSecondary}" FontSize="10" />
        </StackPanel>
    </Border>
</UserControl>
