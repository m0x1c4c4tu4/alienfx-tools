<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="winrt::AlienFX::Controls::FanCurveControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource AlienSurface}" CornerRadius="8" BorderBrush="{StaticResource AlienBorder}" BorderThickness="1" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Fan Speed vs Temperature" Style="{StaticResource SectionHeaderStyle}" />
            <Canvas x:Name="CurveCanvas" Grid.Row="1" MinHeight="200" Background="{StaticResource AlienSurfaceAlt}" CornerRadius="4" />
            <StackPanel Orientation="Horizontal" Grid.Row="2" Spacing="8" HorizontalAlignment="Center" Margin="0,8,0,0">
                <TextBlock Text="Temperature (°C)" Foreground="{StaticResource AlienTextSecondary}" />
                <TextBlock Text="→" Foreground="{StaticResource AlienTextSecondary}" />
                <TextBlock Text="Fan Speed (%)" Foreground="{StaticResource AlienTextSecondary}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
