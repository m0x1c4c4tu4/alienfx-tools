<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="winrt::AlienFX::Controls::ColorButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button x:Name="ColorBtn" Width="48" Height="48" Click="ColorBtn_Click">
        <Button.Content>
            <Grid>
                <Rectangle x:Name="ColorPreview" Fill="Black" RadiusX="4" RadiusY="4" />
                <TextBlock x:Name="HexText" Text="#000000" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" Foreground="White" />
            </Grid>
        </Button.Content>
        <Button.Flyout>
            <Flyout>
                <ColorPicker x:Name="Picker" IsAlphaEnabled="False" ColorChanged="Picker_ColorChanged" />
            </Flyout>
        </Button.Flyout>
    </Button>
</UserControl>
