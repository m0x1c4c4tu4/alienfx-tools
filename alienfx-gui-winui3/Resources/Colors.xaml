<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Alienware Dark Theme Colors -->
    <SolidColorBrush x:Key="AlienBackground" Color="#0F0F0F" />
    <SolidColorBrush x:Key="AlienSurface" Color="#1A1A1A" />
    <SolidColorBrush x:Key="AlienSurfaceAlt" Color="#242424" />
    <SolidColorBrush x:Key="AlienAccent" Color="#00D4AA" />
    <SolidColorBrush x:Key="AlienAccentHover" Color="#00EABF" />
    <SolidColorBrush x:Key="AlienWarning" Color="#FF6B35" />
    <SolidColorBrush x:Key="AlienError" Color="#FF3B30" />
    <SolidColorBrush x:Key="AlienTextPrimary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AlienTextSecondary" Color="#A0A0A0" />
    <SolidColorBrush x:Key="AlienBorder" Color="#333333" />

    <!-- Spacing -->
    <x:Double x:Key="SpaceXS">4</x:Double>
    <x:Double x:Key="SpaceSM">8</x:Double>
    <x:Double x:Key="SpaceMD">16</x:Double>
    <x:Double x:Key="SpaceLG">24</x:Double>
    <x:Double x:Key="SpaceXL">32</x:Double>

</ResourceDictionary>
