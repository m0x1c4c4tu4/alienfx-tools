<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Page Title Style -->
    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Semibold" />
        <Setter Property="Foreground" Value="{StaticResource AlienTextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,24" />
    </Style>

    <!-- Section Header Style -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Semibold" />
        <Setter Property="Foreground" Value="{StaticResource AlienTextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!-- Card Style -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AlienSurface}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="{StaticResource SpaceMD}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!-- Accent Button Style -->
    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AlienAccent}" />
        <Setter Property="Foreground" Value="#000000" />
    </Style>

    <!-- Slider Style -->
    <Style x:Key="AlienSliderStyle" TargetType="Slider">
        <Setter Property="Margin" Value="0,4" />
    </Style>

</ResourceDictionary>
