<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="winrt::AlienFX::ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="16">
            <TextBlock Text="Profiles" Style="{StaticResource PageTitleStyle}" />
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Active Profiles" Style="{StaticResource SectionHeaderStyle}" />
                    <ListView x:Name="ProfilesList" MinHeight="120" SelectionMode="Single"
                              ItemsSource="{Binding Profiles}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Trigger}" Foreground="{StaticResource AlienTextSecondary}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Add Profile" Style="{StaticResource AccentButtonStyle}"
                                Click="AddProfile_Click" />
                        <Button Content="Remove Profile"
                                Click="RemoveProfile_Click" />
                        <Button Content="Copy Active"
                                Click="CopyActive_Click" />
                        <Button Content="Reset"
                                Click="Reset_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Profile Settings" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBox x:Name="ProfileName" Header="Profile Name" PlaceholderText="Enter profile name"
                             Text="{Binding ProfileName, Mode=TwoWay}" />
                    <ComboBox x:Name="TriggerType" Header="Trigger Type"
                              SelectedIndex="{Binding TriggerType, Mode=TwoWay}">
                        <ComboBoxItem Content="None" />
                        <ComboBoxItem Content="Application" />
                        <ComboBoxItem Content="Power State" />
                        <ComboBoxItem Content="Hotkey" />
                    </ComboBox>
                    <TextBox x:Name="TriggerApp" Header="Trigger Application" PlaceholderText="Application path"
                             Text="{Binding TriggerApp, Mode=TwoWay}" />
                    <TextBox x:Name="TriggerKeys" Header="Trigger Keys" PlaceholderText="Key combination"
                             Text="{Binding TriggerKeys, Mode=TwoWay}" />
                    <CheckBox x:Name="DefaultProfile" Content="Set as Default Profile"
                              IsChecked="{Binding DefaultProfile, Mode=TwoWay}" />
                    <CheckBox x:Name="PriorityProfile" Content="Priority Mode"
                              IsChecked="{Binding PriorityProfile, Mode=TwoWay}" />
                    <CheckBox x:Name="ProfileDim" Content="Dimmed Mode"
                              IsChecked="{Binding ProfileDim, Mode=TwoWay}" />
                    <CheckBox x:Name="ForegroundProfile" Content="Active When Foreground"
                              IsChecked="{Binding ForegroundProfile, Mode=TwoWay}" />
                    <CheckBox x:Name="RunScript" Content="Run Script on Activate"
                              IsChecked="{Binding RunScript, Mode=TwoWay}" />
                    <TextBox x:Name="ScriptName" Header="Script Path" PlaceholderText="Script file path"
                             Text="{Binding ScriptName, Mode=TwoWay}" />
                    <CheckBox x:Name="FanProfile" Content="Apply Fan Profile"
                              IsChecked="{Binding FanProfile, Mode=TwoWay}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Device Effects" Style="{StaticResource SectionHeaderStyle}" />
                    <ListView x:Name="DeviceEffects" MinHeight="80" SelectionMode="Single"
                              ItemsSource="{Binding DeviceEffects}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding Device}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Effect}" Foreground="{StaticResource AlienTextSecondary}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Configure Effects" Style="{StaticResource AccentButtonStyle}"
                                Click="ConfigureEffects_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
