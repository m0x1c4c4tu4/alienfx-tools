<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="winrt::AlienFX::ColorsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AlienFX.ViewModel">
    <Page.DataContext>
        <vm:ColorsViewModel />
    </Page.DataContext>
    <ScrollViewer>
        <StackPanel Spacing="16">
            <TextBlock Text="Color Effects" Style="{StaticResource PageTitleStyle}" />

            <!-- Effects List -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Active Effects" Style="{StaticResource SectionHeaderStyle}" />
                    <ListView x:Name="EffectsList" MinHeight="120" SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Rectangle Width="24" Height="24" Fill="{Binding ColorBrush}" RadiusX="4" RadiusY="4" />
                                    <TextBlock Text="{Binding EffectName}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding EffectType}" Foreground="{StaticResource AlienTextSecondary}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Add Effect" Style="{StaticResource AccentButtonStyle}" Click="AddEffectBtn_Click" />
                        <Button Content="Remove Effect" Click="RemoveEffectBtn_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Effect Configuration -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Effect Settings" Style="{StaticResource SectionHeaderStyle}" />
                    <ComboBox x:Name="EffectType" Header="Effect Type" PlaceholderText="Select effect" SelectedIndex="{Binding EffectType, Mode=TwoWay}">
                        <ComboBoxItem Content="Static" />
                        <ComboBoxItem Content="Pulse" />
                        <ComboBoxItem Content="Morph" />
                        <ComboBoxItem Content="Breath" />
                        <ComboBoxItem Content="Color Cycle" />
                        <ComboBoxItem Content="Random" />
                    </ComboBox>
                    <ComboBox x:Name="ColorMode" Header="Color Mode" SelectedIndex="{Binding ColorMode, Mode=TwoWay}">
                        <ComboBoxItem Content="Global" />
                        <ComboBoxItem Content="Per-Zone" />
                        <ComboBoxItem Content="Per-Light" />
                    </ComboBox>
                    <Slider x:Name="Tempo" Header="Tempo" Minimum="0" Maximum="1000" Value="{Binding Tempo, Mode=TwoWay}" />
                    <Slider x:Name="Length" Header="Length" Minimum="1" Maximum="100" Value="{Binding Length, Mode=TwoWay}" />
                    <ColorPicker x:Name="ColorPicker" IsAlphaEnabled="False" Color="{Binding SelectedColor, Mode=TwoWay}" />
                    <Button x:Name="TestColor" Content="Test Color" HorizontalAlignment="Left" Click="TestColorBtn_Click" />
                </StackPanel>
            </Border>

            <!-- Flags -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Options" Style="{StaticResource SectionHeaderStyle}" />
                    <CheckBox x:Name="CircleFlag" Content="Circle" IsChecked="{Binding Circle, Mode=TwoWay}" />
                    <CheckBox x:Name="RandomFlag" Content="Random" IsChecked="{Binding Random, Mode=TwoWay}" />
                    <CheckBox x:Name="PhaseFlag" Content="Phase" IsChecked="{Binding Phase, Mode=TwoWay}" />
                    <CheckBox x:Name="BackgroundFlag" Content="Background" IsChecked="{Binding Background, Mode=TwoWay}" />
                    <CheckBox x:Name="ReversePos" Content="Reverse Position" IsChecked="{Binding ReversePos, Mode=TwoWay}" />
                    <CheckBox x:Name="Spectrum" Content="Spectrum Gradient" IsChecked="{Binding Spectrum, Mode=TwoWay}" />
                    <CheckBox x:Name="Reverse" Content="Reverse" IsChecked="{Binding Reverse, Mode=TwoWay}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
