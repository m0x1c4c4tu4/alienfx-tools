<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="winrt::AlienFX::FansPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="16">
            <TextBlock Text="Fan Control" Style="{StaticResource PageTitleStyle}" />
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Power Mode" Style="{StaticResource SectionHeaderStyle}" />
                    <ComboBox x:Name="PowerMode" Header="Active Profile">
                        <ComboBoxItem Content="Balanced" />
                        <ComboBoxItem Content="Performance" />
                        <ComboBoxItem Content="Ultra Performance" />
                        <ComboBoxItem Content="Full Speed" />
                        <ComboBoxItem Content="Custom" />
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox x:Name="ACBoost" Header="AC Boost">
                            <ComboBoxItem Content="Default" />
                            <ComboBoxItem Content="Level 1" />
                            <ComboBoxItem Content="Level 2" />
                        </ComboBox>
                        <ComboBox x:Name="DCBoost" Header="DC Boost">
                            <ComboBoxItem Content="Default" />
                            <ComboBoxItem Content="Level 1" />
                            <ComboBoxItem Content="Level 2" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Fan Curve" Style="{StaticResource SectionHeaderStyle}" />
                    <Border x:Name="FanCurveArea" Height="250" Background="{StaticResource AlienSurfaceAlt}" CornerRadius="8" BorderBrush="{StaticResource AlienBorder}" BorderThickness="1">
                        <TextBlock Text="Fan curve visualization" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource AlienTextSecondary}" />
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Apply Curve" Style="{StaticResource AccentButtonStyle}" />
                        <Button Content="Reset" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Temperature &amp; Fans" Style="{StaticResource SectionHeaderStyle}" />
                    <ListView x:Name="TempList" MinHeight="80" Header="Temperatures">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding SensorName}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ValueText}" Foreground="{StaticResource AlienAccent}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <ListView x:Name="FanList" MinHeight="80" Header="Fans">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding FanName}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SpeedText}" Foreground="{StaticResource AlienAccent}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Overboost" Style="{StaticResource SectionHeaderStyle}" />
                    <Slider x:Name="TCC" Header="TCC" Minimum="0" Maximum="100" Value="50" />
                    <Slider x:Name="XMP" Header="XMP" Minimum="0" Maximum="100" Value="50" />
                    <Button x:Name="Overboost" Content="Enable Overboost" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" />
                    <Button x:Name="ResetBoost" Content="Reset Boost" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
