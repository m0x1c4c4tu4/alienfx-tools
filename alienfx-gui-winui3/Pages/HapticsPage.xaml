<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="winrt::AlienFX::HapticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="16">
            <TextBlock Text="Audio Haptics" Style="{StaticResource PageTitleStyle}" />
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Frequency Groups" Style="{StaticResource SectionHeaderStyle}" />
                    <ListView x:Name="FreqGroups" MinHeight="100" SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding GroupName}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding FreqRange}" Foreground="{StaticResource AlienTextSecondary}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Add Group" Style="{StaticResource AccentButtonStyle}" />
                        <Button Content="Remove Group" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Visualization" Style="{StaticResource SectionHeaderStyle}" />
                    <Border x:Name="FreqBarsArea" Height="150" Background="{StaticResource AlienSurfaceAlt}" CornerRadius="8" BorderBrush="{StaticResource AlienBorder}" BorderThickness="1">
                        <TextBlock Text="Frequency bars visualization" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource AlienTextSecondary}" />
                    </Border>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Settings" Style="{StaticResource SectionHeaderStyle}" />
                    <Slider x:Name="Tact" Header="Tact" Minimum="0" Maximum="1000" Value="500" />
                    <Slider x:Name="Width" Header="Width" Minimum="1" Maximum="50" Value="10" />
                    <CheckBox x:Name="HapticsCircle" Content="Circle" />
                    <CheckBox x:Name="HapticsRandom" Content="Random" />
                    <CheckBox x:Name="HapticsPhase" Content="Phase" />
                    <CheckBox x:Name="HapticsBackground" Content="Background" />
                    <CheckBox x:Name="HapticsReversePos" Content="Reverse Position" />
                    <CheckBox x:Name="HapticsSpectrum" Content="Spectrum" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
