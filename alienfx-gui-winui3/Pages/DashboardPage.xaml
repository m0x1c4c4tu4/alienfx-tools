<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="winrt::AlienFX::DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AlienFX.ViewModel">
    <Page.DataContext>
        <vm:MainViewModel />
    </Page.DataContext>
    <ScrollViewer>
        <StackPanel Spacing="16">
            <TextBlock Text="Dashboard" Style="{StaticResource PageTitleStyle}" />

            <!-- Device Summary Card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Connected Devices" Style="{StaticResource SectionHeaderStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <StackPanel>
                            <TextBlock Text="{x:Bind DeviceCount(), Mode=OneWay}"
                                       FontSize="48" FontWeight="Bold"
                                       Foreground="{StaticResource AlienAccent}" />
                            <TextBlock Text="Devices"
                                       FontSize="14"
                                       Foreground="{StaticResource AlienTextSecondary}" />
                        </StackPanel>
                        <ListView ItemsSource="{Binding Devices}" MinWidth="200" MaxHeight="160"
                                  BorderBrush="{StaticResource AlienBorder}" BorderThickness="1"
                                  CornerRadius="4" Padding="4">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Padding="4,2">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                 Fill="{StaticResource AlienAccent}" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Quick Actions Card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Quick Actions" Style="{StaticResource SectionHeaderStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ToggleButton Content="Toggle Lights"
                                      IsChecked="{Binding LightsOn, Mode=TwoWay}"
                                      Click="ToggleLightsBtn_Click"
                                      MinWidth="140" />
                        <ToggleButton Content="Toggle Dimmed"
                                      IsChecked="{Binding LightsDimmed, Mode=TwoWay}"
                                      Click="ToggleDimmedBtn_Click"
                                      MinWidth="140" />
                        <ToggleButton Content="Toggle Effects"
                                      IsChecked="{Binding EffectsEnabled, Mode=TwoWay}"
                                      Click="ToggleEffectsBtn_Click"
                                      MinWidth="140" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sensor Summary Card -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="System Sensors" Style="{StaticResource SectionHeaderStyle}" />
                    <TextBlock Text="{x:Bind SensorSummary(), Mode=OneWay}"
                               Foreground="{StaticResource AlienTextSecondary}"
                               TextWrapping="Wrap" />
                    <ListView ItemsSource="{x:Bind Sensors(), Mode=OneWay}"
                              MinHeight="80" MaxHeight="200"
                              BorderBrush="{StaticResource AlienBorder}" BorderThickness="1"
                              CornerRadius="4" Padding="4">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="16" Padding="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" Grid.Column="0" />
                                    <TextBlock Grid.Column="1">
                                        <Run Text="{Binding Value}" />
                                        <Run Text="{Binding Unit}" />
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
